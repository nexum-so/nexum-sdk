{
  "name": "@nexum-so/sdk",
  "version": "0.1.2",
  "description": "TypeScript SDK for Nexum Protocol — AI agent registry with ZK confidential payments on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.mjs",
      "require": "./dist/agent.js"
    },
    "./zk": {
      "types": "./dist/zk.d.ts",
      "import": "./dist/zk.mjs",
      "require": "./dist/zk.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/agent.ts src/zk.ts --format cjs,esm --dts --external @coral-xyz/anchor --external @solana/web3.js --external @solana/spl-token --external @bonfida/spl-name-service --external snarkjs --external circomlibjs --external tweetnacl",
    "dev": "tsup src/index.ts src/agent.ts src/zk.ts --format cjs,esm --dts --watch --external @coral-xyz/anchor --external @solana/web3.js --external @solana/spl-token --external @bonfida/spl-name-service --external snarkjs --external circomlibjs --external tweetnacl",
    "lint": "tsc --noEmit",
    "test": "ts-mocha -p tsconfig.json -t 10000 tests/*.test.ts"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.0",
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/express": "^4.17.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.30.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "optionalDependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.0",
    "tweetnacl": "^1.0.3"
  },
  "keywords": [
    "solana",
    "nexum",
    "a2a",
    "x402",
    "zk",
    "groth16",
    "ai-agents",
    "confidential-payments"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexum-so/nexum-sdk"
  }
}
